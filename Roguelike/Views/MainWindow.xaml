<Window x:Class="Roguelike.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Roguelike.ViewModels"
        xmlns:views="clr-namespace:Roguelike.Views"
        Title="FileLipov" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Focusable="True" Loaded="Window_Loaded" Background="#1E1E1E">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Esc" Command="{Binding MovementCommand}" CommandParameter="Escape"/>

        <KeyBinding Key="W" Command="{Binding MovementCommand}" CommandParameter="Up"/>
        <KeyBinding Key="Up" Command="{Binding MovementCommand}" CommandParameter="Up"/>
        <KeyBinding Key="S" Command="{Binding MovementCommand}" CommandParameter="Down"/>
        <KeyBinding Key="Down" Command="{Binding MovementCommand}" CommandParameter="Down"/>
        <KeyBinding Key="A" Command="{Binding MovementCommand}" CommandParameter="Left"/>
        <KeyBinding Key="Left" Command="{Binding MovementCommand}" CommandParameter="Left"/>
        <KeyBinding Key="D" Command="{Binding MovementCommand}" CommandParameter="Right"/>
        <KeyBinding Key="Right" Command="{Binding MovementCommand}" CommandParameter="Right"/>
    </Window.InputBindings>

    <Grid>
        <Grid Visibility="{Binding IsPlayingVisible, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding PlayerHP, StringFormat='HP: {0}'}" Foreground="LightGreen" FontSize="22" FontWeight="SemiBold" Margin="15,0"/>
                <TextBlock Text="{Binding CurrentLevel, StringFormat='Этаж: {0}'}" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="15,0"/>
                <TextBlock Text="{Binding Score, StringFormat='Очки: {0}'}" Foreground="Gold" FontSize="22" FontWeight="SemiBold" Margin="15,0"/>
            </StackPanel>

            <Border Grid.Row="1" Margin="20" BorderBrush="DimGray" BorderThickness="3" Background="Black">
                <ItemsControl ItemsSource="{Binding MapCells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding MapWidth}" Rows="{Binding MapHeight}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0.5">
                                <Rectangle Fill="{Binding CellColor}" />
                                <TextBlock Text="{Binding CellText}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>

        <views:GameOverView Visibility="{Binding IsGameOverVisible, Converter={StaticResource BoolToVis}}"/>

        <views:MainMenuView Visibility="{Binding IsMainMenuVisible, Converter={StaticResource BoolToVis}}"/>

        <Grid Visibility="{Binding IsPauseVisible, Converter={StaticResource BoolToVis}}" Background="#DD000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="ПАУЗА" FontSize="56" Foreground="White" FontWeight="Bold" Margin="0,0,0,40" HorizontalAlignment="Center"/>

                <Button Content="Продолжить" Command="{Binding PauseCommand}" FontSize="24" Padding="30,10" Margin="0,0,0,15" Background="DimGray" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Вкл/Выкл Звук" Command="{Binding ToggleSoundCommand}" FontSize="24" Padding="30,10" Margin="0,0,0,15" Background="DimGray" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Выйти в главное меню" Command="{Binding GoToMenuCommand}" FontSize="24" Padding="30,10" Margin="0,0,0,15" Background="DimGray" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Выйти из игры" Command="{Binding ExitCommand}" FontSize="24" Padding="30,10" Background="DarkRed" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>