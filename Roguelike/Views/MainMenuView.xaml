<UserControl x:Class="Roguelike.Views.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#1E1E1E">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="FileLipov" FontSize="48" Foreground="Gold" FontWeight="Bold" Margin="0,0,0,30" HorizontalAlignment="Center"/>
            <Button Content="Начать игру" Command="{Binding StartGameCommand}" FontSize="24" Padding="30,10" Background="DimGray" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>