<UserControl x:Class="Roguelike.Views.GameOverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#CC000000">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="ВЫ ПОГИБЛИ" FontSize="56" Foreground="Red" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Score, StringFormat='Итоговые очки: {0}'}" FontSize="28" Foreground="White" Margin="0,0,0,40" HorizontalAlignment="Center"/>

            <Button Content="Играть снова" Command="{Binding StartGameCommand}" FontSize="24" Padding="20,10" Margin="0,0,0,15" Background="DimGray" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="В главное меню" Command="{Binding GoToMenuCommand}" FontSize="24" Padding="20,10" Background="DimGray" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>
